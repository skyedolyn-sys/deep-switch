{
  "name": "deep-switch",
  "version": "0.1.0",
  "description": "API provider switcher for Deep Code — connect any LLM vendor to Deep Code CLI",
  "main": "dist/main/index.js",
  "author": {
    "name": "Deep Switch contributors",
    "email": "dev@deepswitch.app"
  },
  "license": "MIT",
  "homepage": "https://github.com/skyedolyn-sys/deep-switch#readme",
  "bugs": {
    "url": "https://github.com/skyedolyn-sys/deep-switch/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skyedolyn-sys/deep-switch.git"
  },
  "keywords": [
    "deep-code",
    "deepseek",
    "cli",
    "api",
    "provider",
    "switcher",
    "electron",
    "openai-compatible",
    "menu-bar"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tauri dev",
    "build": "tauri build",
    "dev:electron": "concurrently \"npm run dev:electron-main\" \"npm run dev:renderer\"",
    "dev:electron-main": "tsc -p tsconfig.main.json && VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "dev:renderer": "vite",
    "build:electron": "npm run build:electron-main && npm run build:renderer",
    "build:electron-main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "start:electron": "electron .",
    "pack:electron": "electron-builder --dir",
    "dist:electron": "electron-builder",
    "dist:electron-mac": "bash scripts/build-mac.sh",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "@lobehub/fluent-emoji": "^4.1.0",
    "@lobehub/icons": "^5.10.1",
    "@lobehub/icons-static-svg": "^1.91.0",
    "@lobehub/ui": "^5.19.2",
    "@tauri-apps/api": "^2.11.1",
    "antd": "^6.5.0",
    "framer-motion": "^12.42.2",
    "i18next": "^26.3.4",
    "i18next-browser-languagedetector": "^8.2.1",
    "react-i18next": "^17.0.8",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/cli": "^2.11.4",
    "@types/express": "^4.17.21",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.3.3",
    "vite": "^5.0.10"
  },
  "build": {
    "appId": "com.deepswitch.app",
    "productName": "Deep Switch",
    "files": [
      "dist/**/*",
      "public/**/*"
    ],
    "extraResources": [
      {
        "from": "src/renderer/locales",
        "to": "locales"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
